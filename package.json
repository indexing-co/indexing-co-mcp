{
  "name": "indexing-co-mcp",
  "version": "1.0.0",
  "description": "MCP server for streaming live blockchain data from Indexing Co pipelines",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run install-skill",
    "install-skill": "node scripts/install-skill.js",
    "dev": "tsc --watch",
